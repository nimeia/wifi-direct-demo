<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>uap10.0.19041</TargetFramework>
    <OutputType>AppContainerExe</OutputType>
    <RootNamespace>WiFiDirectDemo.Windows</RootNamespace>
    <ApplicationManifest>Package.appxmanifest</ApplicationManifest>
    <Platforms>x86;x64;ARM64</Platforms>
    <RuntimeIdentifiers>win10-x86;win10-x64;win10-arm64</RuntimeIdentifiers>
    <TargetPlatformMinVersion>10.0.19041.0</TargetPlatformMinVersion>
    <TargetPlatformVersion>10.0.19041.0</TargetPlatformVersion>
    <GenerateAppInstallerFile>false</GenerateAppInstallerFile>
    <AppxBundle>Never</AppxBundle>
    <AppxPackage>false</AppxPackage>
    <UseDotNetNativeToolchain>false</UseDotNetNativeToolchain>
    <Nullable>enable</Nullable>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.NETCore.UniversalWindowsPlatform" Version="6.2.14" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\WiFiDirectDemo.Protocol\WiFiDirectDemo.Protocol.csproj" />
  </ItemGroup>
  <ItemGroup>
    <None Include="Package.appxmanifest" />
  </ItemGroup>
</Project>

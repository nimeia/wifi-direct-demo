<Page
    x:Class="WiFiDirectDemo.Windows.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WiFiDirectDemo.Windows"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Unloaded="Page_Unloaded"
    mc:Ignorable="d">

    <Page.Resources>
        <LinearGradientBrush x:Key="PageBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF091320" Offset="0.0" />
            <GradientStop Color="#FF12263E" Offset="0.6" />
            <GradientStop Color="#FF18314B" Offset="1.0" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#CC0D1B2E" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#334A6A8A" />
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="16" />
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF2F7DF6" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14,8" />
        </Style>
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1FFFFFFF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="BorderBrush" Value="#55FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Opacity" Value="0.88" />
            <Setter Property="Margin" Value="0,10,0,4" />
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled">
            <Grid Padding="20" RowSpacing="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Spacing="4">
                    <TextBlock Text="Wi‑Fi Direct Port Access Demo"
                               Foreground="White"
                               FontSize="31"
                               FontFamily="Bahnschrift"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Discover peers, connect, then expose a local Windows port through the Wi‑Fi Direct link."
                               Foreground="#E6FFFFFF"
                               TextWrapping="WrapWholeWords" />
                </StackPanel>

                <Grid Grid.Row="1" ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="14">
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Connection"
                                           Foreground="White"
                                           FontSize="20"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="Start host mode, discover nearby peers, then connect."
                                           Foreground="#D9FFFFFF"
                                           TextWrapping="WrapWholeWords" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="Start Host"
                                            Click="StartHost_Click"
                                            Style="{StaticResource PrimaryButtonStyle}" />
                                    <Button Content="Discover"
                                            Click="Discover_Click"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                </StackPanel>
                                <Button Content="Connect Selected Peer"
                                        Click="ConnectSelected_Click"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                                <TextBlock Text="Peers"
                                           Foreground="White"
                                           Margin="0,8,0,0"
                                           FontWeight="SemiBold" />
                                <ListView x:Name="PeersListView"
                                          Height="220"
                                          Background="#19FFFFFF"
                                          BorderBrush="#26FFFFFF"
                                          BorderThickness="1"
                                          ItemsSource="{x:Bind Peers}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="local:PeerInfoViewModel">
                                            <StackPanel Padding="6,4">
                                                <TextBlock Text="{x:Bind DisplayName}"
                                                           Foreground="White"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="{x:Bind DeviceId}"
                                                           Foreground="#CCFFFFFF"
                                                           Opacity="0.84"
                                                           TextWrapping="WrapWholeWords"
                                                           FontSize="12" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Port Access Configuration"
                                           Foreground="White"
                                           FontSize="20"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="Expose one ingress port and forward traffic to a local service on this Windows machine."
                                           Foreground="#D9FFFFFF"
                                           TextWrapping="WrapWholeWords" />
                                <TextBlock Text="Ingress Port (Wi‑Fi Direct side)"
                                           Foreground="White"
                                           Style="{StaticResource FieldLabelStyle}" />
                                <TextBox x:Name="ExposePortTextBox" Text="51080" />
                                <TextBlock Text="Target Host (localhost only)"
                                           Foreground="White"
                                           Style="{StaticResource FieldLabelStyle}" />
                                <TextBox x:Name="TargetHostTextBox" Text="127.0.0.1" />
                                <TextBlock Text="Target Port (local service)"
                                           Foreground="White"
                                           Style="{StaticResource FieldLabelStyle}" />
                                <TextBox x:Name="TargetPortTextBox" Text="8080" />
                                <TextBlock Text="Allowed Target Ports (comma separated)"
                                           Foreground="White"
                                           Style="{StaticResource FieldLabelStyle}" />
                                <TextBox x:Name="AllowedPortsTextBox" Text="8080, 8443" />
                                <TextBlock Text="Only ports in this list can be used as forwarding target."
                                           Foreground="#C8FFFFFF"
                                           FontSize="12"
                                           TextWrapping="WrapWholeWords" />
                                <TextBlock x:Name="PortAccessStatusText"
                                           Text="Status: Stopped"
                                           Foreground="#FF7BDCB5"
                                           Margin="0,8,0,4"
                                           FontWeight="SemiBold" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="Start Port Access"
                                            Click="StartPortAccess_Click"
                                            Style="{StaticResource PrimaryButtonStyle}" />
                                    <Button Content="Stop"
                                            Click="StopPortAccess_Click"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="14">
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Activity Log"
                                           Foreground="White"
                                           FontSize="20"
                                           FontWeight="SemiBold" />
                                <ListView x:Name="LogListView"
                                          Height="450"
                                          Background="#19FFFFFF"
                                          BorderBrush="#26FFFFFF"
                                          BorderThickness="1"
                                          ItemsSource="{x:Bind Logs}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"
                                                       Foreground="#F0FFFFFF"
                                                       TextWrapping="WrapWholeWords"
                                                       FontFamily="Consolas"
                                                       FontSize="13" />
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Message Channel"
                                           Foreground="White"
                                           FontSize="20"
                                           FontWeight="SemiBold" />
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="MessageTextBox" PlaceholderText="Type a demo message..." />
                                    <Button Grid.Column="1"
                                            Content="Send"
                                            Click="Send_Click"
                                            Style="{StaticResource PrimaryButtonStyle}" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <TextBlock Grid.Row="2"
                           Text="Tip: Keep Windows in Host mode for Windows ↔ Android tests. Ensure Windows Firewall allows configured ingress and target service ports."
                           Foreground="#CCFFFFFF"
                           TextWrapping="WrapWholeWords"
                           Opacity="0.9" />
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
